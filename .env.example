# Copy this file to .env and fill in values. .env is gitignored — never commit filled keys.

# Alpaca (paper is the default; do not flip BASE_URL without the three-opt-in live gate)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_JUDGE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_FINAL=claude-sonnet-4-6

# Polygon.io (free tier to start; $29/mo when news matters)
POLYGON_API_KEY=

# Budgets and caps
MAX_LLM_DAILY_USD=5

# Live gate — must be 0 in paper phase. Orchestrator additionally requires interactive "YES" at startup.
LIVE=0

# Alerting (Phase 5) — pick one backend and populate when wiring AlertDispatcher
ALERT_BACKEND=
ALERT_GMAIL_USER=
ALERT_GMAIL_APP_PASSWORD=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
